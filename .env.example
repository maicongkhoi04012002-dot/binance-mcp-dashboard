# ── Email Alerts (Gmail) ──────────────────────────────────────────────
# Hướng dẫn lấy App Password:
#   1. Bật 2-Step Verification: https://myaccount.google.com/security
#   2. Tạo App Password:        https://myaccount.google.com/apppasswords
#      → Chọn "Mail" → Copy 16 ký tự → paste vào EMAIL_APP_PASSWORD

EMAIL_SENDER=your_gmail@gmail.com
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_RECIPIENT=maicongkhoi04012002@gmail.com

# ── TradingView Webhook ──────────────────────────────────────────────
# Secret token to validate incoming webhook requests (leave blank = no auth)
WEBHOOK_SECRET=
WEBHOOK_PORT=8765

# ── Binance API (cho binance_trader.py) ──────────────────────────────
# Lấy API key tại:
#   TESTNET: https://testnet.binance.vision  (free, no real money)
#   LIVE:    https://www.binance.com/en/my/settings/api-management

BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# true  = dùng Testnet (https://testnet.binance.vision) — KHUYÊN DÙNG khi mới test
# false = dùng Live (THẬT — cẩn thận!)
BINANCE_TESTNET=true

# true  = Dry-run mode: tính toán nhưng KHÔNG đặt lệnh thật
# false = Đặt lệnh thật (chỉ bật sau khi test kỹ!)
BINANCE_DRY_RUN=true

# ── Risk Management ──────────────────────────────────────────────────
MAX_USDT_PER_TRADE=20    # Tối đa $ mỗi lệnh
MAX_OPEN_TRADES=3        # Tối đa bao nhiêu vị thế cùng lúc
STOP_LOSS_PCT=2.0        # Stop loss 2%
TAKE_PROFIT_PCT=4.0      # Take profit 4%
