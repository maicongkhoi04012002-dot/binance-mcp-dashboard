// ═══════════════════════════════════════════════════════════════════════════
// TV-MCP Signal Strategy v2.0
// ───────────────────────────────────────────────────────────────────────────
// Tích hợp: RSI(14) + EMA(9) + WMA(45) + MACD(12,26,9) + Volume Filter
//
// HƯỚNG DẪN SỬ DỤNG:
// ─────────────────────────────────────────────────────────────────────────
// 1. Mở TradingView → New Indicator → dán toàn bộ script này vào
// 2. Thêm vào chart của từng cặp: BTCUSDT, ETHUSDT, BNBUSDT, SOLUSDT, XRPUSDT
// 3. Đổi timeframe lần lượt: 1D, 4H, 1H
// 4. Tạo Alert cho mỗi chart:
//    - Condition: "TV-MCP Signal" → "Any alert() function call"
//    - Webhook URL: https://YOUR_DOMAIN/webhook
//    - Message: để trống (script tự tạo JSON)
// 5. Lặp lại cho tất cả 5 coin × 3 timeframe = 15 alerts tổng cộng
// ═══════════════════════════════════════════════════════════════════════════

//@version=5
indicator("TV-MCP Signal v2", overlay=true, max_bars_back=500)

// ─── INPUTS ──────────────────────────────────────────────────────────────────
grp_ind = "📊 Indicators"
rsiLen  = input.int(14, "RSI Length",  minval=2,  maxval=50,  group=grp_ind)
emaLen  = input.int(9,  "EMA Length",  minval=2,  maxval=50,  group=grp_ind)
wmaLen  = input.int(45, "WMA Length",  minval=5,  maxval=200, group=grp_ind)
macdFast = input.int(12, "MACD Fast",  minval=2,  maxval=50,  group=grp_ind)
macdSlow = input.int(26, "MACD Slow",  minval=5,  maxval=100, group=grp_ind)
macdSig  = input.int(9,  "MACD Signal",minval=2,  maxval=50,  group=grp_ind)

grp_flt = "🔍 Filters"
rsiOverbought = input.int(70, "RSI Overbought", minval=60, maxval=90, group=grp_flt)
rsiOversold   = input.int(30, "RSI Oversold",   minval=10, maxval=40, group=grp_flt)
rsiBullMin    = input.int(50, "RSI Bull Min (>)", minval=40, maxval=60, group=grp_flt)
rsiBearMax    = input.int(50, "RSI Bear Max (<)", minval=40, maxval=60, group=grp_flt)
useVolFilter  = input.bool(false, "Use Volume Filter", group=grp_flt)
volMulti      = input.float(1.2, "Volume Multiplier (x avg)", minval=1.0, maxval=3.0, step=0.1, group=grp_flt)

grp_wh = "🌐 Webhook"
webhookUrl = input.string("https://YOUR_DOMAIN/webhook", "Webhook URL", group=grp_wh)
webhookSecret = input.string("", "X-TV-Secret (optional)", group=grp_wh)

// ─── INDICATORS ───────────────────────────────────────────────────────────────
rsiVal  = ta.rsi(close, rsiLen)
ema9    = ta.ema(close, emaLen)
wma45   = ta.wma(close, wmaLen)

[macdLine, signalLine, histLine] = ta.macd(close, macdFast, macdSlow, macdSig)

volAvg  = ta.sma(volume, 20)
volOk   = not useVolFilter or (volume >= volAvg * volMulti)

// ─── SIGNAL CONDITIONS ────────────────────────────────────────────────────────
bullish = ema9 > wma45 and rsiVal > rsiBullMin and histLine > 0 and volOk
bearish = ema9 < wma45 and rsiVal < rsiBearMax and histLine < 0 and volOk

// Chỉ phát tín hiệu khi có sự thay đổi trạng thái (tránh spam)
var string prevSignal = "NEUTRAL"
buySignal  = bullish and prevSignal != "BUY"
sellSignal = bearish and prevSignal != "SELL"

if buySignal
    prevSignal := "BUY"
else if sellSignal
    prevSignal := "SELL"
else if not bullish and not bearish
    prevSignal := "NEUTRAL"

// ─── ALERT JSON PAYLOAD ───────────────────────────────────────────────────────
// Binance feed tự ghi nhận {{interval}} theo format: 60, 240, 1D
// → match đúng với tf_aliases trong webhook_server.py
makeJson(action) =>
    '{"ticker":"' + syminfo.ticker + 
    '","timeframe":"' + str.tostring(timeframe.period) + 
    '","action":"' + action + 
    '","price":' + str.tostring(close, "#.########") + 
    ',"close":' + str.tostring(close, "#.########") + 
    ',"open":' + str.tostring(open, "#.########") + 
    ',"high":' + str.tostring(high, "#.########") + 
    ',"low":' + str.tostring(low, "#.########") + 
    ',"volume":' + str.tostring(volume, "#.##") + 
    ',"rsi":' + str.tostring(rsiVal, "#.##") + 
    ',"ema9":' + str.tostring(ema9, "#.########") + 
    ',"wma45":' + str.tostring(wma45, "#.########") + 
    ',"macd":' + str.tostring(macdLine, "#.########") + 
    ',"macd_sig":' + str.tostring(signalLine, "#.########") + 
    ',"macd_hist":' + str.tostring(histLine, "#.########") + 
    ',"source":"tradingview"}'

// ─── FIRE ALERTS ─────────────────────────────────────────────────────────────
if buySignal
    alert(makeJson("BUY"), alert.freq_once_per_bar_close)

if sellSignal
    alert(makeJson("SELL"), alert.freq_once_per_bar_close)

// ─── VISUALS ──────────────────────────────────────────────────────────────────
plot(ema9,  "EMA 9",   color=color.new(color.blue,   0), linewidth=2)
plot(wma45, "WMA 45",  color=color.new(color.orange,  0), linewidth=2)

// Buy/Sell markers
plotshape(buySignal,  title="BUY",  style=shape.labelup,   location=location.belowbar,
          color=color.new(color.green, 0), text="BUY",  textcolor=color.white, size=size.small)
plotshape(sellSignal, title="SELL", style=shape.labeldown, location=location.abovebar,
          color=color.new(color.red,   0), text="SELL", textcolor=color.white, size=size.small)

// RSI background color khi overbought/oversold
bgcolor(rsiVal >= rsiOverbought ? color.new(color.red,   90) : na, title="Overbought Zone")
bgcolor(rsiVal <= rsiOversold   ? color.new(color.green, 90) : na, title="Oversold Zone")

// ─── INFO TABLE ───────────────────────────────────────────────────────────────
var table infoTable = table.new(position.top_right, 2, 6,
     bgcolor=color.new(color.black, 70), border_width=1,
     border_color=color.new(color.gray, 50))

if barstate.islast
    rsiColor = rsiVal >= rsiOverbought ? color.red : rsiVal <= rsiOversold ? color.green : color.gray
    sigColor = bullish ? color.green : bearish ? color.red : color.gray
    sigText  = bullish ? "🟢 BULL" : bearish ? "🔴 BEAR" : "⚪ NEUTRAL"

    table.cell(infoTable, 0, 0, "RSI",     text_color=color.gray,  text_size=size.small)
    table.cell(infoTable, 1, 0, str.tostring(rsiVal, "#.#"), text_color=rsiColor, text_size=size.small)
    table.cell(infoTable, 0, 1, "EMA9",    text_color=color.gray,  text_size=size.small)
    table.cell(infoTable, 1, 1, str.tostring(ema9,   "#.##"), text_color=color.blue,   text_size=size.small)
    table.cell(infoTable, 0, 2, "WMA45",   text_color=color.gray,  text_size=size.small)
    table.cell(infoTable, 1, 2, str.tostring(wma45,  "#.##"), text_color=color.orange, text_size=size.small)
    table.cell(infoTable, 0, 3, "MACD H",  text_color=color.gray,  text_size=size.small)
    table.cell(infoTable, 1, 3, str.tostring(histLine, "#.####"), 
               text_color=histLine > 0 ? color.green : color.red, text_size=size.small)
    table.cell(infoTable, 0, 4, "Vol",     text_color=color.gray,  text_size=size.small)
    table.cell(infoTable, 1, 4, volOk ? "✓ OK" : "✗ Low",
               text_color=volOk ? color.green : color.red, text_size=size.small)
    table.cell(infoTable, 0, 5, "Signal",  text_color=color.gray,  text_size=size.small)
    table.cell(infoTable, 1, 5, sigText,   text_color=sigColor,    text_size=size.small)
